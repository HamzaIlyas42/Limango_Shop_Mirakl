<?xml version="1.0" encoding="UTF-8"?>
<CustomField xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>MerchantCompanyName__c</fullName>
    <description>Field needed for the integration to Merchant Center, to deliver correct invoice or return address company name</description>
    <externalId>false</externalId>
    <formula>IF(
    NOT(ISBLANK(AddressCompanyName__c)),
    AddressCompanyName__c,
    Account__r.Name
)</formula>
    <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
    <label>Merchant Company Name</label>
    <required>false</required>
    <trackHistory>false</trackHistory>
    <trackTrending>false</trackTrending>
    <type>Text</type>
    <unique>false</unique>
</CustomField>
